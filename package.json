{
  "name": "civitas-vote-token",
  "version": "0.2.0",
  "description": "Arquitectura experimental para voto digital verificável com raciocínio formal, auditoria heurística e criptografia educativa baseada em Matemática Finita.",
  "type": "module",
  "scripts": {
    "demo": "tsx src/dev-demo/demo.ts",
    "simulate": "tsx src/simulation/election-simulator.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm test && npm run demo && npm run simulate"
  },
  "keywords": [
    "anonymous-credentials",
    "audit-engine",
    "blind-signatures",
    "dpll",
    "e-voting",
    "electronic-voting",
    "end-to-end-verifiability",
    "event-sourcing",
    "finite-fields",
    "formal-methods",
    "heuristic-search",
    "merkle-tree",
    "privacy",
    "property-testing",
    "shamir-secret-sharing"
  ],
  "author": "Caio Miguel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
